# Copy to `.env` (gitignored) and fill in. Do NOT commit real values.

# Neon Postgres connection string (use a dev/throwaway branch for the POC).
# Example: postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Pinned Claude judge model (recorded per benchmark). Default is fine for the POC.
JUDGE_MODEL=claude-opus-4-8

# Shared secret guarding the dev-tunnel key-ingest route (set when you wire Teams).
KEY_INGEST_SECRET=
