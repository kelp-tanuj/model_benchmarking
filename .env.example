# Copy to `.env` (gitignored) and fill in. Do NOT commit real values.

# Neon Postgres connection string (use a dev/throwaway branch for the POC).
# Example: postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Pinned Claude judge model (recorded per benchmark). Default is fine for the POC.
JUDGE_MODEL=claude-opus-4-8

# Shared secret guarding the dev-tunnel key-ingest route (set when you wire Teams).
KEY_INGEST_SECRET=

# --- Teams (Power Automate Workflows) ---
# Outbound (informational cards): "When a Teams webhook request is received" flow URL.
TEAMS_POST_FLOW_URL=
# Outbound (interactive cards): a "post adaptive card and wait for a response" flow that
# forwards the response to the daemon's /inbox. Optional — falls back to TEAMS_POST_FLOW_URL.
TEAMS_CARD_FLOW_URL=
# Daemon HTTP endpoint. The /callback/key and /inbox routes are what you expose via a dev tunnel
# (both require X-Kelp-Secret = KEY_INGEST_SECRET).
HTTP_HOST=127.0.0.1
HTTP_PORT=8765
